<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-background-color: #0f0f0f;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cinema.ticket.controllers.BookingController">

    <top>
        <VBox spacing="8"
              style="-fx-background-color: #16213e; -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 3);">
            <Label fx:id="movieTitleLabel" text="🎬 Название фильма"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;">
                <font><Font name="System Bold" size="18.0"/></font>
            </Label>
            <Label fx:id="stepLabel" text="Шаг 1: Выберите сеанс"
                   style="-fx-font-size: 13; -fx-text-fill: #e50914; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;">
            <VBox fx:id="seatsContainer" spacing="20" alignment="TOP_CENTER"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="20" bottom="20" left="20" right="20"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="12"
              style="-fx-background-color: #16213e; -fx-padding: 18;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, -3);">
            <VBox spacing="5">
                <Label fx:id="selectedSeatsLabel" text="Выбранные места: нет"
                       style="-fx-font-size: 12; -fx-text-fill: #a0a0a0;"/>
                <Label fx:id="totalPriceLabel" text="Общая стоимость: 0 руб."
                       style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: white;">
                    <font><Font name="System Bold" size="15.0"/></font>
                </Label>
            </VBox>

            <HBox spacing="12">
                <Button fx:id="bookButton" text="Забронировать"
                        onAction="#onBookClick" disable="true"
                        prefHeight="46.0" prefWidth="170.0"
                        style="-fx-background-color: #1db954;
                               -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-font-size: 14; -fx-background-radius: 8;
                               -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Отмена" onAction="#onCancelClick"
                        prefHeight="46.0" prefWidth="140.0"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #a0a0a0;
                               -fx-border-color: #2a2a4a;
                               -fx-border-width: 2;
                               -fx-border-radius: 8;
                               -fx-font-weight: bold;
                               -fx-font-size: 14;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>