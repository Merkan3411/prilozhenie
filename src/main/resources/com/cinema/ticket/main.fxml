<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="30.0"
      style="-fx-background-color: linear-gradient(to bottom, #0f0f0f, #1a1a2e);"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.ticket.controllers.MainController">

    <padding>
        <Insets bottom="60.0" left="40.0" right="40.0" top="60.0" />
    </padding>

    <VBox alignment="CENTER" spacing="12">
        <Label style="-fx-font-size: 72;" text="🎬"/>
        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="CineMax">
            <font><Font name="System Bold" size="42.0"/></font>
        </Label>
        <Label style="-fx-text-fill: #a0a0a0; -fx-font-style: italic;"
               text="Лучшие фильмы в лучшем качестве">
            <font><Font size="15.0"/></font>
        </Label>
    </VBox>


    <VBox alignment="CENTER" spacing="14"
          style="-fx-background-color: #16213e;
                 -fx-background-radius: 20;
                 -fx-padding: 40;
                 -fx-effect: dropshadow(gaussian, rgba(229,9,20,0.3), 30, 0, 0, 10);">

        <Button mnemonicParsing="false" onAction="#onLoginClick"
                prefHeight="52.0" prefWidth="300.0"
                style="-fx-background-color: #e50914;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 10;
                       -fx-font-size: 16;
                       -fx-cursor: hand;"
                text="Войти" />

        <Button mnemonicParsing="false" onAction="#onRegisterClick"
                prefHeight="52.0" prefWidth="300.0"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #e50914;
                       -fx-border-color: #e50914;
                       -fx-border-width: 2;
                       -fx-border-radius: 10;
                       -fx-font-weight: bold;
                       -fx-font-size: 16;
                       -fx-cursor: hand;"
                text="Регистрация" />

        <Button mnemonicParsing="false" onAction="#onGuestClick"
                prefHeight="48.0" prefWidth="300.0"
                style="-fx-background-color: #2a2a4a;
                       -fx-text-fill: #a0a0a0;
                       -fx-font-weight: bold;
                       -fx-background-radius: 10;
                       -fx-font-size: 15;
                       -fx-cursor: hand;"
                text="Продолжить как гость" />
    </VBox>
</VBox>
