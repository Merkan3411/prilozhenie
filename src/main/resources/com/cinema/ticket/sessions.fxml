<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.ticket.controllers.SessionsController"
      spacing="10.0">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Заголовок -->
    <Label fx:id="titleLabel" text="Сеансы">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <!-- Фильтры -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="Дата:" />
        <ComboBox fx:id="dateFilter" onAction="#onFilterChange" prefWidth="120.0" />
        <Label text="Время:" />
        <ComboBox fx:id="timeFilter" onAction="#onFilterChange" prefWidth="150.0" />
        <Button mnemonicParsing="false" onAction="#onMoviesClick" text="К фильмам" />
        <Button mnemonicParsing="false" onAction="#onBackClick" text="Назад" />
    </HBox>

    <!-- Список сеансов -->
    <ScrollPane fitToWidth="true" vbarPolicy="ALWAYS" prefHeight="600.0">
        <VBox fx:id="sessionsContainer" spacing="10.0" style="-fx-padding: 10;" />
    </ScrollPane>
</VBox>