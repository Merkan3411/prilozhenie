<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="25.0"
      style="-fx-background-color: linear-gradient(to bottom, #0f0f0f, #1a1a2e);"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.ticket.controllers.LoginController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Label style="-fx-font-size: 52;" text="🎬"/>
        <Label style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Добро пожаловать">
            <font><Font name="System Bold" size="26.0"/></font>
        </Label>
        <Label style="-fx-text-fill: #d0d0d0;" text="Войдите в свой аккаунт">
            <font><Font size="14.0"/></font>
        </Label>
    </VBox>

    <VBox alignment="CENTER" spacing="16"
          style="-fx-background-color: #16213e;
                 -fx-background-radius: 16;
                 -fx-padding: 35;
                 -fx-effect: dropshadow(gaussian, rgba(229,9,20,0.25), 24, 0, 0, 6);">

        <VBox alignment="CENTER_LEFT" spacing="7">
            <Label style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold;"
                   text="Имя пользователя">
                <font><Font name="System Bold" size="13.0"/></font>
            </Label>
            <TextField fx:id="usernameField" prefWidth="320.0"
                       promptText="Введите имя пользователя"
                       style="-fx-background-color: #22294a;
                              -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #7a7a9a;
                              -fx-background-radius: 8;
                              -fx-border-color: #3a3a6a;
                              -fx-border-radius: 8;
                              -fx-padding: 12;
                              -fx-font-size: 14;"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="7">
            <Label style="-fx-text-fill: #e0e0e0; -fx-font-weight: bold;" text="Пароль">
                <font><Font name="System Bold" size="13.0"/></font>
            </Label>
            <PasswordField fx:id="passwordField" prefWidth="320.0"
                           promptText="Введите пароль"
                           style="-fx-background-color: #22294a;
                                  -fx-text-fill: #ffffff;
                                  -fx-prompt-text-fill: #7a7a9a;
                                  -fx-background-radius: 8;
                                  -fx-border-color: #3a3a6a;
                                  -fx-border-radius: 8;
                                  -fx-padding: 12;
                                  -fx-font-size: 14;"/>
        </VBox>

        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #ff4d4d; -fx-font-size: 12;
                      -fx-font-weight: bold;" wrapText="true"/>

        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#onLoginClick"
                prefHeight="50.0" prefWidth="320.0"
                style="-fx-background-color: #e50914;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-font-size: 15;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, rgba(229,9,20,0.4), 12, 0, 0, 3);"
                text="Войти"/>

        <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackClick"
                prefHeight="44.0" prefWidth="320.0"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d0d0d0;
                       -fx-border-color: #3a3a6a;
                       -fx-border-width: 2;
                       -fx-border-radius: 8;
                       -fx-font-weight: bold;
                       -fx-font-size: 14;
                       -fx-cursor: hand;"
                text="Назад"/>
    </VBox>

    <VBox alignment="CENTER" spacing="10">
        <Hyperlink onAction="#onRegisterLinkClick"
                   style="-fx-text-fill: #e50914;
                          -fx-border-color: transparent;
                          -fx-font-weight: bold;
                          -fx-font-size: 13;"
                   text="Нет аккаунта? Зарегистрируйтесь"/>
        <Hyperlink onAction="#onGuestLoginClick"
                   style="-fx-text-fill: #9090b0;
                          -fx-border-color: transparent;
                          -fx-font-size: 12;"
                   text="Продолжить как гость"/>
    </VBox>
</VBox>
