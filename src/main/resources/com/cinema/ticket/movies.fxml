<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.ticket.controllers.MoviesController"
      spacing="20.0"
      style="-fx-background-color: #0f0f0f;">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <HBox spacing="15.0" alignment="CENTER_LEFT"
          style="-fx-background-color: #16213e;
                 -fx-background-radius: 12;
                 -fx-padding: 15 20;
                 -fx-effect: dropshadow(gaussian, rgba(229,9,20,0.15), 10, 0, 0, 3);">
        <Label fx:id="welcomeLabel" text="Фильмы"
               style="-fx-text-fill: #ffffff; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>


        <Region HBox.hgrow="ALWAYS"/>

        <TextField fx:id="searchField" promptText="🔍  Поиск фильмов..." prefWidth="240.0"
                   style="-fx-background-color: #22294a;
                          -fx-text-fill: #ffffff;
                          -fx-prompt-text-fill: #7a7a9a;
                          -fx-background-radius: 8;
                          -fx-border-color: #3a3a6a;
                          -fx-border-radius: 8;
                          -fx-padding: 9 14;
                          -fx-font-size: 13;"/>

        <Button mnemonicParsing="false" onAction="#onSearchClick"
                style="-fx-background-color: #e50914;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 9 20;
                       -fx-cursor: hand;
                       -fx-font-size: 13;"
                text="Поиск"/>

        <Button mnemonicParsing="false" onAction="#onProfileClick"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d0d0d0;
                       -fx-border-color: #3a3a6a;
                       -fx-border-width: 1;
                       -fx-border-radius: 8;
                       -fx-padding: 9 16;
                       -fx-cursor: hand;
                       -fx-font-weight: bold;
                       -fx-font-size: 13;"
                text="👤 Профиль"/>
    </HBox>

    <Label text="📽 Все фильмы"
           style="-fx-text-fill: #ffffff; -fx-font-weight: bold;">
        <font><Font name="System Bold" size="18.0"/></font>
    </Label>

    <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-border-color: transparent;
                       -fx-background: #0f0f0f;">
        <VBox style="-fx-background-color: #0f0f0f; -fx-padding: 5;">
            <GridPane fx:id="moviesGrid" hgap="20.0" vgap="20.0"
                      style="-fx-padding: 10; -fx-background-color: transparent;"/>
        </VBox>
    </ScrollPane>
</VBox>
