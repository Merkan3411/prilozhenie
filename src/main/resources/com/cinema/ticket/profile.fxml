<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cinema.ticket.controllers.ProfileController"
      spacing="20.0"
      style="-fx-background-color: #0f0f0f;"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets bottom="20.0" left="25.0" right="25.0" top="20.0"/>
    </padding>

    <HBox spacing="15.0" alignment="CENTER_LEFT"
          style="-fx-background-color: #16213e;
                 -fx-background-radius: 12;
                 -fx-padding: 15 20;
                 -fx-effect: dropshadow(gaussian, rgba(229,9,20,0.15), 10, 0, 0, 3);">

        <Label text="Личный кабинет"
               style="-fx-text-fill: #ffffff; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="22.0"/></font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="registerButton" mnemonicParsing="false" onAction="#onRegisterClick"
                style="-fx-background-color: #1db954;
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 9 18;
                       -fx-cursor: hand; -fx-font-size: 13;"
                text="Зарегистрироваться"/>
        <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackClick"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #d0d0d0;
                       -fx-border-color: #3a3a6a; -fx-border-width: 1;
                       -fx-border-radius: 8; -fx-padding: 9 16;
                       -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13;"
                text="← Назад"/>
        <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#onLogoutClick"
                style="-fx-background-color: #e50914;
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 9 18;
                       -fx-cursor: hand; -fx-font-size: 13;"
                text="Выйти"/>
    </HBox>

    <VBox spacing="15.0"
          style="-fx-background-color: #16213e;
                 -fx-background-radius: 14;
                 -fx-padding: 25;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 3);">

        <Label text="ℹ️ Информация о пользователе"
               style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 16;">
            <font><Font name="System Bold" size="16.0"/></font>
        </Label>

        <Label fx:id="userInfoLabel" text="Загрузка..."
               style="-fx-text-fill: #e0e0e0;
                      -fx-font-size: 14;
                      -fx-padding: 8 0;
                      -fx-line-spacing: 6;"/>

        <HBox spacing="12.0">
            <Button fx:id="editProfileButton" mnemonicParsing="false"
                    onAction="#onEditProfileClick"
                    style="-fx-background-color: #1db954;
                           -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 10 22;
                           -fx-cursor: hand; -fx-font-size: 13;"
                    text="✏️ Редактировать"/>
            <Button fx:id="changePasswordButton" mnemonicParsing="false"
                    onAction="#onChangePasswordClick"
                    style="-fx-background-color: #e59014;
                           -fx-text-fill: white; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-padding: 10 22;
                           -fx-cursor: hand; -fx-font-size: 13;"
                    text="🔒 Сменить пароль"/>
        </HBox>
    </VBox>

    <VBox spacing="12.0" VBox.vgrow="ALWAYS">
        <Label text="📋 История бронирований"
               style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 16;">
            <font><Font name="System Bold" size="16.0"/></font>
        </Label>

        <ScrollPane fx:id="ticketsScrollPane" fitToWidth="true"
                    vbarPolicy="AS_NEEDED" prefHeight="400.0"
                    style="-fx-background-color: transparent;
                           -fx-border-color: transparent;
                           -fx-background: #0f0f0f;">
            <VBox fx:id="ticketsContainer" spacing="15.0"
                  style="-fx-padding: 5; -fx-background-color: #0f0f0f;"/>
        </ScrollPane>
    </VBox>
</VBox>
